---
/*
 * BaseLayout — root HTML shell for every page.
 *
 * Responsibilities:
 *   - <head> meta: charset, viewport, title, description, canonical, OpenGraph
 *   - Google Fonts: Playfair Display + Inter (preconnect, display=swap)
 *   - Loads global tokens.css + base.css (base imports tokens)
 *   - Provides slots for SiteHeader / SiteFooter (Task #7) and main content
 *   - Skip-to-content link for a11y baseline
 *
 * Slots (consumed by Task #7 — Shell components):
 *   - "head"   → extra <head> markup (per-page JSON-LD, additional meta)
 *   - "header" → SiteHeader (sticky)
 *   - default  → page content (wrapped in <main id="main">)
 *   - "footer" → SiteFooter
 *
 * Props:
 *   - title       (required)  page <title>
 *   - description (optional)  meta description + og:description
 *   - lang        (optional)  'es' (default) | 'en'
 *   - ogImage     (optional)  absolute or site-relative path for og:image
 *   - pathname    (optional)  used to derive canonical URL
 */

import '../styles/base.css';
import { hreflangAlternates, t } from '../lib/i18n';

export interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
  ogImage?: string;
  pathname?: string;
}

// Locale resolution order:
//   1. Explicit `lang` prop (translators pass `<BaseLayout lang="en" ...>` per architecture §2).
//   2. `Astro.currentLocale` from the i18n routing config (derived from the URL).
//   3. Spanish default — preserves existing behavior on Spanish pages.
// Falling back to `Astro.currentLocale` makes the lang attribute robust if a page forgets
// to pass the prop, so a page at `/en/...` still emits `<html lang="en">` automatically.
const detectedLocale = (Astro.currentLocale as 'es' | 'en' | undefined) ?? 'es';

const {
  title,
  description = 'AI Safety Mexico — Investigación, educación y gobernanza de IA en México.',
  lang = detectedLocale,
  ogImage,
  pathname,
} = Astro.props;

// Site-wide default OG image (used when a page does not pass its own).
// Picked because it is the most identity-rich asset shipped today.
// TODO(content): replace with a 1200×630 social card optimised for OG.
const DEFAULT_OG_IMAGE = '/images/observatorio.png';

const canonicalUrl = pathname ? new URL(pathname, Astro.site) : Astro.url;
const resolvedOgImage = ogImage ?? DEFAULT_OG_IMAGE;
const ogImageUrl = resolvedOgImage.startsWith('http')
  ? resolvedOgImage
  : new URL(resolvedOgImage, Astro.site).toString();

// hreflang alternates — emit <link rel="alternate"> for both locales plus
// `x-default` (points to Spanish, the canonical locale). Requires a usable
// pathname; falls back to Astro.url.pathname when `pathname` is omitted.
// Spec: docs/I18N-ARCHITECTURE.md §6.
const alternatePath = pathname ?? Astro.url.pathname;
const alternates =
  Astro.site != null ? hreflangAlternates(alternatePath, Astro.site) : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {/*
      Browser-language detection — runs ONLY on the Spanish home (`/`).
      Spec: docs/I18N-ARCHITECTURE.md §5. Placed before fonts/CSS so the
      redirect fires synchronously, minimising flash-of-Spanish-content.
      Reads localStorage('aismx_locale'); on first visit with `en*` navigator
      language, writes the pref and `location.replace('/en')`. Never runs on
      deep links or interior pages. Storage failures are swallowed.
    */}
    {pathname === '/' && (
      <script is:inline set:html={`
        (function () {
          try {
            var stored = null;
            try { stored = localStorage.getItem('aismx_locale'); } catch (e) {}
            if (stored === 'es' || stored === 'en') return;

            var nav = (navigator.languages && navigator.languages[0]) || navigator.language || '';
            var prefersEn = /^en\\b/i.test(nav);

            if (prefersEn) {
              try { localStorage.setItem('aismx_locale', 'en'); } catch (e) {}
              location.replace('/en');
            } else {
              try { localStorage.setItem('aismx_locale', 'es'); } catch (e) {}
            }
          } catch (e) { /* swallow */ }
        })();
      `} />
    )}

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />

    {alternates && (
      <>
        <link rel="alternate" hreflang="es" href={alternates.es} />
        <link rel="alternate" hreflang="en" href={alternates.en} />
        <link rel="alternate" hreflang="x-default" href={alternates.xDefault} />
      </>
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:site_name" content="AI Safety Mexico" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Google Fonts: Playfair Display + Inter (preconnect + display=swap) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">{t(lang, 'a11y.skipToContent')}</a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
