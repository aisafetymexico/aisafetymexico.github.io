---
/**
 * Accordion — accessible disclosure pattern.
 *
 * Spec:
 *  - docs/DESIGN-SYSTEM.md §6.5.
 *  - WAI-ARIA Authoring Practices: "Disclosure (Show/Hide)" / "Accordion".
 *
 * A11y guarantees:
 *  - Each item is a <button aria-expanded> that toggles a region by aria-controls.
 *  - Region uses role="region" + aria-labelledby (named by its trigger).
 *  - Keyboard: Enter/Space to toggle (native button), ArrowUp/Down/Home/End
 *    move focus between item triggers.
 *  - Hidden panels use `hidden`; chevron rotation is purely decorative.
 *  - Respects `prefers-reduced-motion` (chevron transition disabled).
 *
 * Props:
 *  - items: Array<{ title: string, content: string }>  // content = HTML/text
 *    For richer content, use the `<slot name="item-{idx}" />` pattern via
 *    the `slotMode` flag.
 *  - allowMultiple?: boolean (default true) — set false for "only one open".
 *  - id?: string
 */
export interface AccordionItem {
  title: string;
  content?: string;
}

export interface Props {
  items: AccordionItem[];
  allowMultiple?: boolean;
  id?: string;
}

const { items, allowMultiple = true, id } = Astro.props;
const rootId = id || `accordion-${Math.random().toString(36).slice(2, 9)}`;
---

{items.length > 0 && (
  <div
    class="accordion"
    id={rootId}
    data-accordion
    data-allow-multiple={allowMultiple ? 'true' : 'false'}
  >
    {items.map((item, idx) => {
      const triggerId = `${rootId}-trigger-${idx}`;
      const panelId = `${rootId}-panel-${idx}`;
      return (
        <div class="accordion__item">
          <h3 class="accordion__heading">
            <button
              type="button"
              id={triggerId}
              class="accordion__trigger"
              aria-expanded="false"
              aria-controls={panelId}
              data-accordion-trigger
            >
              <span class="accordion__title">{item.title}</span>
              <span class="accordion__icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="14" height="14" focusable="false">
                  <path
                    d="M3 5l5 6 5-6"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </button>
          </h3>
          <div
            id={panelId}
            role="region"
            aria-labelledby={triggerId}
            class="accordion__panel"
            data-accordion-panel
            hidden
          >
            <div class="accordion__content">
              {item.content && <Fragment set:html={item.content} />}
              <slot name={`item-${idx}`} />
            </div>
          </div>
        </div>
      );
    })}
  </div>
)}

<script>
  (() => {
    const ATTR = 'data-accordion-bound';

    const init = (root: HTMLElement) => {
      if (root.getAttribute(ATTR) === '1') return;
      root.setAttribute(ATTR, '1');

      const triggers = Array.from(
        root.querySelectorAll<HTMLButtonElement>('[data-accordion-trigger]')
      );
      const allowMultiple = root.getAttribute('data-allow-multiple') !== 'false';

      const setOpen = (trigger: HTMLButtonElement, open: boolean) => {
        const id = trigger.getAttribute('aria-controls');
        if (!id) return;
        const panel = document.getElementById(id);
        if (!panel) return;
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        panel.hidden = !open;
        trigger.classList.toggle('is-open', open);
      };

      triggers.forEach((trigger, idx) => {
        trigger.addEventListener('click', () => {
          const isOpen = trigger.getAttribute('aria-expanded') === 'true';
          if (!allowMultiple && !isOpen) {
            triggers.forEach(t => t !== trigger && setOpen(t, false));
          }
          setOpen(trigger, !isOpen);
        });

        trigger.addEventListener('keydown', (e: KeyboardEvent) => {
          let target: HTMLButtonElement | null = null;
          switch (e.key) {
            case 'ArrowDown':
              target = triggers[(idx + 1) % triggers.length];
              break;
            case 'ArrowUp':
              target = triggers[(idx - 1 + triggers.length) % triggers.length];
              break;
            case 'Home':
              target = triggers[0];
              break;
            case 'End':
              target = triggers[triggers.length - 1];
              break;
            default:
              return;
          }
          e.preventDefault();
          target?.focus();
        });
      });
    };

    const bootstrap = () => {
      document.querySelectorAll<HTMLElement>('[data-accordion]').forEach(init);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootstrap);
    } else {
      bootstrap();
    }
  })();
</script>

<style>
  .accordion {
    width: 100%;
    border-top: 1px solid var(--color-border);
  }

  .accordion__item {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion__heading {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
  }

  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4, 16px);
    width: 100%;
    padding: var(--space-5, 20px) var(--space-4, 16px);
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: var(--fs-h6, 1.1rem);
    font-weight: var(--fw-bold, 700);
    color: var(--color-text-heading);
    transition: background var(--transition, 0.25s ease), color var(--transition, 0.25s ease);
  }
  .accordion__trigger:hover {
    background: var(--color-accent-soft);
  }
  .accordion__trigger:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: -2px;
  }

  .accordion__title { flex: 1; }

  .accordion__icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    transition: transform var(--transition, 0.25s ease);
  }
  .accordion__trigger.is-open .accordion__icon { transform: rotate(180deg); }

  .accordion__panel {
    overflow: hidden;
  }
  .accordion__panel[hidden] { display: none; }

  .accordion__content {
    padding: 0 var(--space-4, 16px) var(--space-5, 20px);
    color: var(--color-text-primary);
    line-height: var(--lh-relaxed, 1.7);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: var(--fs-body, 1rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .accordion__icon { transition: none; }
  }
</style>
