---
/**
 * PageHero — Interior page variant.
 *
 * Spec: docs/DESIGN-SYSTEM.md §6.2; Task #8; RAND-DIFF §2 / §4 (color-restrainer).
 *
 * Pattern reference (docs/INSPIRATION.md):
 *  - A1 (single editorial headline + supporting paragraph)
 *
 * White surface, left-aligned, breadcrumb above an extra-bold sans H1 with an
 * optional lead paragraph. No eyebrow, no navy band, no decorative chrome —
 * the breadcrumb carries wayfinding and the H1 carries focal weight.
 *
 * Props:
 *  - eyebrow?:     LEGACY — accepted for backwards compatibility but no longer
 *                  rendered. Pages should drop the prop.
 *  - title:        page H1 (Playfair, --fs-h1)
 *  - description?: lead paragraph
 *  - breadcrumb?:  ordered list of breadcrumb items; rendered via Breadcrumb
 *
 * Tokens only — no literal hex values, no new hues introduced.
 */
import Breadcrumb from './Breadcrumb.astro';
import type { Breadcrumb as BreadcrumbProp } from '../lib/types';

export interface Props {
  /** @deprecated No longer rendered (RAND-DIFF §2.2). Kept for prop compatibility. */
  eyebrow?: string;
  title: string;
  description?: string;
  breadcrumb?: BreadcrumbProp;
}

const { title, description, breadcrumb } = Astro.props;

if (!title) throw new Error('PageHero: `title` is required.');

const hasBreadcrumb = breadcrumb && breadcrumb.items && breadcrumb.items.length > 0;
---

<section class="page-hero" aria-labelledby="page-hero-title">
  <div class="page-hero__inner">
    {hasBreadcrumb && (
      <div class="page-hero__breadcrumb">
        <Breadcrumb items={breadcrumb!.items} />
      </div>
    )}

    <h1 id="page-hero-title" class="page-hero__title">{title}</h1>

    {description && (
      <p class="page-hero__description">{description}</p>
    )}
  </div>
</section>

<style>
  .page-hero {
    background-color: var(--color-bg-base);
    color: var(--color-text-primary);
    padding-block: var(--space-9) var(--space-8);
    text-align: start;
  }

  @media (min-width: 768px) {
    .page-hero {
      padding-block: var(--space-12) var(--space-10);
    }
  }

  .page-hero__inner {
    width: 100%;
    max-width: var(--container-narrow);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  @media (min-width: 480px) {
    .page-hero__inner {
      padding-inline: var(--container-padding-md);
    }
  }

  /* Breadcrumb sits above the H1 in the same column. Keep tones light-mode. */
  .page-hero__breadcrumb {
    text-align: start;
    margin-bottom: var(--space-4);
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h1);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    /* Dark-mode subtle (PALETTE-MAPPING §4.5): hero h1 overrides default
       cream heading color to peach so it carries the focal poster weight. */
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .page-hero__description {
    font-family: var(--font-body);
    font-size: var(--fs-lead);
    font-weight: var(--fw-regular);
    line-height: var(--lh-loose);
    color: var(--color-text-primary);
    max-width: 640px;
    margin-inline-start: 0;
    margin-inline-end: 0;
    margin-bottom: 0;
  }
</style>
