---
/**
 * Header — sticky site header (navy background) with logo + primary nav.
 *
 * Spec:
 *  - docs/ARCHITECTURE.md §3 (sticky + scrolled state, hamburger <768px).
 *  - docs/INSPIRATION.md A7 (flat horizontal nav, no mega menu).
 *  - docs/DESIGN-SYSTEM.md §6.1 (`SiteHeader` props: `currentPath:string`).
 *
 * Behaviours:
 *  - Sticks to top with --z-sticky.
 *  - Adds `.site-header--scrolled` after the user has scrolled past 80px,
 *    which compresses padding and applies --shadow-header.
 *  - Logo top-left → `/`. Visually distinct as a link with focus ring.
 *  - Nav (incl. mobile drawer) lives in <Nav />.
 *
 * Props:
 *  - currentPath: string — optional. Defaults to `Astro.url.pathname`. This is
 *    the *real* current pathname (including deep paths like `/projects/vigia`)
 *    and is the value forwarded to <LanguageSwitcher> so it can compute the
 *    cross-locale equivalent (`/en/projects/vigia`) and preserve deep links.
 *  - navActivePath: string — optional. When passed, <Nav> uses this path to
 *    compute its active-link highlight instead of `currentPath`. Use this on
 *    sub-pages whose parent section should glow in the nav (e.g. on
 *    `/projects/vigia` pass `navActivePath="/projects"` so the "Projects" nav
 *    item highlights). When omitted, Nav falls back to `currentPath` (which
 *    already handles parent-child matches via startsWith).
 *  - logoSrc / logoAlt: optional overrides.
 *  - siteName: optional override for the wordmark next to the logo.
 */
import Nav from './Nav.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { NavItem } from '../lib/types';
import { t, localizedPath, type Locale } from '../lib/i18n';

export interface Props {
  currentPath?: string;
  navActivePath?: string;
  navItems?: NavItem[];
  logoSrc?: string;
  logoAlt?: string;
  siteName?: string;
  lang?: Locale;
}

const {
  currentPath = Astro.url.pathname,
  navActivePath,
  navItems,
  logoSrc = '/images/aisafetymx_logo.webp',
  logoAlt = 'AI Safety Mexico',
  siteName = 'AI Safety Mexico',
  lang = 'es',
} = Astro.props;

const navPath = navActivePath ?? currentPath;

const brandHref = localizedPath(lang, '/');
const brandAria = t(lang, 'header.aria.brandHome');
---

<header class="site-header" data-site-header>
  <div class="site-header__inner">
    <a class="site-header__logo" href={brandHref} aria-label={brandAria}>
      <img
        class="site-header__logo-img"
        src={logoSrc}
        alt={logoAlt}
        width="48"
        height="48"
        loading="eager"
        decoding="async"
      />
      <span class="site-header__wordmark">{siteName}</span>
    </a>

    <div class="site-header__cluster">
      <Nav currentPath={navPath} items={navItems} lang={lang} />
      <LanguageSwitcher currentPath={currentPath} />
    </div>
  </div>
</header>

<script>
  /**
   * Toggles `.site-header--scrolled` after the user crosses 80px of scroll.
   * Uses a throttled rAF loop to avoid layout thrashing. Idempotent.
   */
  (() => {
    if ((window as any).__aismxHeaderScrollBound) return;
    (window as any).__aismxHeaderScrollBound = true;

    const init = () => {
      const header = document.querySelector<HTMLElement>('[data-site-header]');
      if (!header) return;

      const SCROLLED_THRESHOLD = 80;
      let ticking = false;
      let scrolled = false;

      const sync = () => {
        const next = window.scrollY > SCROLLED_THRESHOLD;
        if (next !== scrolled) {
          scrolled = next;
          header.classList.toggle('site-header--scrolled', scrolled);
        }
        ticking = false;
      };

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(sync);
          ticking = true;
        }
      }, { passive: true });

      // Initial sync (handles deep-link / refreshed-mid-page cases).
      sync();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  /* Dark-subtle (PALETTE-MAPPING §4.1, validated by editor pipeline):
     Header sits on the page surface (bg-base) with a permanent gray-700
     hairline divider — no impact-band swap, no scroll-conditional border. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--color-bg-base);
    color: var(--color-text-on-dark);
    padding: var(--space-3) 0; /* 12px y — RAND-style compact chrome */
    transition: padding var(--transition);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header--scrolled {
    padding: 8px 0;
  }

  .site-header__inner {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding-inline: var(--container-padding-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  /* Right-side cluster: primary nav + language switcher sit together.
     Spec: docs/I18N-ARCHITECTURE.md §4.5. Inline at every viewport — the
     switcher does not collapse into the mobile drawer. */
  .site-header__cluster {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 1023.98px) {
    .site-header__cluster {
      gap: 8px;
    }
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-on-dark);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: opacity var(--transition);
  }
  .site-header__logo:hover {
    opacity: 0.9;
    color: var(--color-text-on-dark);
  }
  .site-header__logo:focus-visible {
    outline: 2px solid var(--color-accent-secondary);
    outline-offset: 4px;
  }

  .site-header__logo-img {
    height: 48px;
    width: auto;
    transition: height var(--transition);
  }

  .site-header--scrolled .site-header__logo-img {
    height: 40px;
  }

  .site-header__wordmark {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: 1.15rem;
    letter-spacing: 1.5px;
    color: var(--color-text-on-dark);
    line-height: 1;
    white-space: nowrap;
  }

  /* Tighter mobile padding */
  @media (max-width: 479.98px) {
    .site-header__inner {
      padding-inline: var(--container-padding);
    }
    .site-header__logo-img { height: 42px; }
    .site-header--scrolled .site-header__logo-img { height: 36px; }
    .site-header__wordmark {
      font-size: 1.0rem;
      letter-spacing: 1px;
    }
  }

  /* Wordmark hides on very small viewports (logo + name overflow risk) */
  @media (max-width: 359.98px) {
    .site-header__wordmark { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__logo-img {
      transition: none;
    }
  }
</style>
