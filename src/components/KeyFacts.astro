---
/**
 * KeyFacts — horizontal row of factual chips.
 * Used at the top of pages or sections to anchor a few quick numbers/dates.
 *
 * Spec:
 *  - Task #10 props: `{ facts: Array<{icon?, text}> }` (icon now ignored).
 *  - docs/DESIGN-SYSTEM.md §6.4 — KeyFacts.
 *  - docs/RAND-AESTHETIC.md §8 — type-only chips, no leading glyph.
 *  - Pill chips on a warm cream surface; mobile wraps to multiple rows.
 *
 * Backwards-compat: callers may still pass `icon` on each fact; the value is
 * ignored to keep the visual language type-only (Task #26 / RAND-ify).
 */

export interface KeyFact {
  /** @deprecated kept for backwards compatibility; not rendered. */
  icon?: string;
  text: string;
}

export interface Props {
  facts: KeyFact[];
}

const { facts } = Astro.props;
---

<ul class="key-facts" role="list">
  {facts.map((fact) => (
    <li class="key-facts__chip">
      <span class="key-facts__text">{fact.text}</span>
    </li>
  ))}
</ul>

<style>
  .key-facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .key-facts__chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-xs);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    line-height: 1.3;
    transition: border-color var(--transition), background var(--transition);
  }

  .key-facts__chip:hover {
    border-color: var(--color-border-accent);
    background: var(--color-accent-soft);
  }

  .key-facts__text {
    color: inherit;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .key-facts {
      gap: var(--space-3);
    }
    .key-facts__chip {
      padding: var(--space-3) var(--space-5);
    }
  }
</style>
