---
/**
 * PullQuote — large editorial Playfair quote with curly quotation marks and
 * optional attribution line.
 *
 * Spec:
 *  - Task #10 props: `{ quote: string, attribution?: string }`.
 *  - docs/DESIGN-SYSTEM.md §2.4 — Display family + tight line-height.
 *  - Mobile-first: smaller scale on phones, scales up at 768/1024.
 *
 * Renders as a <figure> + <blockquote> for semantics; attribution becomes
 * <figcaption>. The decorative leading quote glyph is aria-hidden so it does
 * not pollute the screen-reader experience.
 */

export interface Props {
  quote: string;
  attribution?: string;
}

const { quote, attribution } = Astro.props;
---

<figure class="pull-quote">
  <span class="pull-quote__mark" aria-hidden="true">&ldquo;</span>
  <blockquote class="pull-quote__text">
    <p>{quote}</p>
  </blockquote>
  {attribution && (
    <figcaption class="pull-quote__attribution">
      <span class="pull-quote__attribution-dash" aria-hidden="true">—</span>
      {attribution}
    </figcaption>
  )}
</figure>

<style>
  .pull-quote {
    position: relative;
    margin: var(--space-8) 0;
    padding: var(--space-6) 0 var(--space-6) var(--space-8);
    border-inline-start: 2px solid var(--color-accent);
  }

  .pull-quote__mark {
    position: absolute;
    top: -8px;
    left: var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(3rem, 1.8rem + 4vw, 5rem);
    font-weight: var(--fw-extrabold);
    color: var(--color-accent-soft);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .pull-quote__text {
    margin: 0;
    padding: 0;
  }

  .pull-quote__text p {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: var(--fw-bold);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-heading);
    margin: 0;
  }

  /* Curly quotes around the visible blockquote text */
  .pull-quote__text p::before { content: '\201C'; }
  .pull-quote__text p::after  { content: '\201D'; }

  .pull-quote__attribution {
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    line-height: var(--lh-normal);
    color: var(--color-text-secondary);
    letter-spacing: var(--ls-wide);
  }

  .pull-quote__attribution-dash {
    margin-inline-end: var(--space-1);
    color: var(--color-accent);
  }

  @media (min-width: 768px) {
    .pull-quote {
      margin: var(--space-10) 0;
      padding: var(--space-7) 0 var(--space-7) var(--space-10);
    }
    .pull-quote__text p {
      font-size: var(--fs-h2);
    }
  }

  @media (min-width: 1024px) {
    .pull-quote {
      padding-inline-start: var(--space-12);
    }
  }
</style>
