---
/**
 * Nav — primary site navigation.
 *
 * Spec: docs/ARCHITECTURE.md §3 + docs/I18N-ARCHITECTURE.md §3.
 *  - Flat horizontal nav, 6 items max (no mega menu — pattern A7 in
 *    docs/INSPIRATION.md).
 *  - Order: About, Research, Programs, Projects, Activities, Get involved.
 *  - "Get involved" rendered as CTA button (visually distinct).
 *  - On <768px the desktop list hides and the MobileMenu drawer takes over.
 *  - Active state: exact match on currentPath, OR currentPath is a child of
 *    the link href (so /projects/vigia highlights /projects).
 *
 * Labels are sourced from the i18n module by default. Pass `items` to
 * override (rare — only for content-specific overrides).
 */
import type { NavItem } from '../lib/types';
import MobileMenu from './MobileMenu.astro';
import { t, localizedPath, type Locale } from '../lib/i18n';

export interface Props {
  currentPath: string;
  items?: NavItem[];
  lang?: Locale;
}

const { currentPath, items, lang = 'es' } = Astro.props;

const defaultItems: NavItem[] = [
  { label: t(lang, 'header.nav.about'),       href: localizedPath(lang, '/about') },
  { label: t(lang, 'header.nav.research'),    href: localizedPath(lang, '/research') },
  { label: t(lang, 'header.nav.programs'),    href: localizedPath(lang, '/programs') },
  { label: t(lang, 'header.nav.projects'),    href: localizedPath(lang, '/projects') },
  { label: t(lang, 'header.nav.activities'),  href: localizedPath(lang, '/activities') },
  { label: t(lang, 'header.nav.getInvolved'), href: localizedPath(lang, '/get-involved'), cta: true },
];

const resolvedItems = items ?? defaultItems;

const isActive = (href: string): boolean => {
  if (!currentPath) return false;
  if (href === '/' || href === '/en') return currentPath === href;
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<nav class="main-nav" aria-label={t(lang, 'header.aria.primaryNav')}>
  {/* Desktop horizontal list — hidden on mobile via media query */}
  <ul class="main-nav__list">
    {resolvedItems.map((item: NavItem) => (
      <li>
        <a
          class:list={[
            'main-nav__link',
            { 'main-nav__link--cta': item.cta },
            { 'is-active': isActive(item.href) },
          ]}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >{item.label}</a>
      </li>
    ))}
  </ul>

  {/* Mobile drawer + hamburger toggle (renders only <768px) */}
  <MobileMenu items={resolvedItems} currentPath={currentPath} lang={lang} />
</nav>

<style>
  .main-nav {
    display: flex;
    align-items: center;
  }

  .main-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .main-nav__link {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border-radius: 6px;
    color: var(--color-text-on-dark-muted);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .main-nav__link:hover {
    color: var(--color-text-on-dark);
    background: var(--peach-tint);
  }
  .main-nav__link:focus-visible {
    outline: 2px solid var(--color-accent-secondary);
    outline-offset: 2px;
  }
  .main-nav__link.is-active {
    color: var(--color-text-on-dark);
    background: var(--peach-border-soft);
  }

  /* "Colabora" link — demoted from pill to plain text-only nav link
     (RAND nav has no filled CTAs in the bar). Slightly heavier weight
     than peers to subtly hint it's the action item, but no fill / radius. */
  .main-nav__link--cta {
    margin-left: 6px;
    padding: 8px 14px;
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-on-dark);
    font-weight: 600;
  }
  .main-nav__link--cta:hover {
    background: var(--peach-tint);
    color: var(--color-text-on-dark);
  }
  .main-nav__link--cta.is-active {
    background: var(--peach-border-soft);
    color: var(--color-text-on-dark);
  }

  /* Hide desktop list on tablet + mobile (MobileMenu takes over).
     RAND only shows the full inline nav at ≥1024px. */
  @media (max-width: 1023.98px) {
    .main-nav__list { display: none; }
  }
</style>
