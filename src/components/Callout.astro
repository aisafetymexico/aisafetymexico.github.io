---
/**
 * Callout — pull-out box with a lateral copper accent border on a cream
 * background. Used to surface a single key paragraph or short list inside a
 * larger editorial flow.
 *
 * Spec:
 *  - Task #10 props: `{ tone?: 'info'|'highlight'|'warning' }` (default highlight).
 *  - docs/DESIGN-SYSTEM.md §6.4 — Callout component.
 *  - Tokens only: cream/navy/copper-tint surfaces, copper accent, --shadow-sm.
 *
 * Tones:
 *  - highlight (default): copper lateral border on cream surface.
 *  - info:                navy lateral border on white surface.
 *  - warning:             gold lateral border on copper-tint surface.
 *
 * Slot:
 *  - default: arbitrary inline / block content (paragraph, list, etc.).
 */

export type CalloutTone = 'info' | 'highlight' | 'warning';

export interface Props {
  tone?: CalloutTone;
}

const { tone = 'highlight' } = Astro.props;
---

<aside class:list={['callout', `callout--${tone}`]} role="note">
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    position: relative;
    margin-block: var(--space-6);
    padding: var(--space-6) var(--space-6) var(--space-6) var(--space-7);
    border-radius: var(--radius-xs);
    background: var(--color-bg-warm);
    color: var(--color-text-primary);
    box-shadow: var(--shadow-sm);
    border-inline-start: 4px solid var(--color-accent);
  }

  .callout__body :global(> :first-child) {
    margin-top: 0;
  }
  .callout__body :global(> :last-child) {
    margin-bottom: 0;
  }

  .callout__body :global(p) {
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-primary);
  }
  .callout__body :global(p + p) {
    margin-top: var(--space-3);
  }

  .callout__body :global(strong) {
    color: var(--color-accent);
    font-weight: var(--fw-semibold);
  }

  .callout__body :global(a) {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .callout__body :global(a:hover),
  .callout__body :global(a:focus-visible) {
    color: var(--color-link-hover);
  }

  /* Tones */
  .callout--highlight {
    background: var(--color-bg-warm);
    border-inline-start-color: var(--color-accent);
  }

  .callout--info {
    background: var(--color-bg-base);
    border-inline-start-color: var(--color-bg-impact);
  }

  .callout--warning {
    background: var(--color-accent-soft);
    border-inline-start-color: var(--color-accent-secondary);
  }

  @media (min-width: 768px) {
    .callout {
      padding: var(--space-7) var(--space-8) var(--space-7) var(--space-9);
      margin-block: var(--space-8);
    }
  }
</style>
