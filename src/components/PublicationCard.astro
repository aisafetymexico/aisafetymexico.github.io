---
/**
 * PublicationCard — research publication card for /research.
 *
 * Spec: docs/DESIGN-SYSTEM.md §6.3 (PublicationCard).
 *
 * Visual: editorial card with title, byline (authors · year · journal),
 * optional abstract, and CTA links to paper and/or podcast. Eyebrow uses the
 * year as the timestamp-style chronology marker (INSPIRATION X5 — research is
 * one of the few areas where dates *are* legitimate signal).
 *
 * Props:
 *  - title:        Publication title (h5 scale).
 *  - authors:      Comma-joined author byline (string OR string[]).
 *  - year:         Publication year (number or string).
 *  - journal?:     Venue / journal / workshop name.
 *  - paperUrl?:    Link to paper PDF / DOI.
 *  - podcastUrl?:  Optional companion podcast / talk link.
 *  - abstract?:    Short blurb (1–3 sentences).
 *  - lang?:        Locale for action labels (defaults to 'es').
 */
import { t, type Locale } from '../lib/i18n';

export interface Props {
  title: string;
  authors: string | string[];
  year: number | string;
  journal?: string;
  paperUrl?: string;
  podcastUrl?: string;
  abstract?: string;
  lang?: Locale;
}

const {
  title,
  authors,
  year,
  journal,
  paperUrl,
  podcastUrl,
  abstract,
  lang = 'es',
} = Astro.props;

const authorString = Array.isArray(authors) ? authors.join(', ') : authors;
---

<article class="publication-card">
  <div class="publication-card__head">
    <span class="publication-card__year">{year}</span>
    {journal && <span class="publication-card__journal">{journal}</span>}
  </div>

  <h3 class="publication-card__title">
    {paperUrl ? (
      <a class="publication-card__title-link" href={paperUrl} target="_blank" rel="noopener noreferrer">
        {title}
      </a>
    ) : (
      title
    )}
  </h3>

  <p class="publication-card__authors">{authorString}</p>

  {abstract && <p class="publication-card__abstract">{abstract}</p>}

  {(paperUrl || podcastUrl) && (
    <div class="publication-card__actions">
      {paperUrl && (
        <a class="publication-card__link" href={paperUrl} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="16" height="16">
            <path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm0 7V3.5L19.5 9H14z"/>
          </svg>
          {t(lang, 'pub.readPaper')}
        </a>
      )}
      {podcastUrl && (
        <a class="publication-card__link" href={podcastUrl} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="16" height="16">
            <path fill="currentColor" d="M12 1a4 4 0 0 0-4 4v6a4 4 0 0 0 8 0V5a4 4 0 0 0-4-4zm5 10a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.92V21h2v-3.08A7 7 0 0 0 19 11h-2z"/>
          </svg>
          {t(lang, 'pub.listenPodcast')}
        </a>
      )}
    </div>
  )}
</article>

<style>
  /* RAND editorial card — square edges, no shadow, no copper stripe.
     Stacked publications separate via a top hairline rule (the parent grid
     can opt into this; standalone cards still read as a single block). */
  .publication-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-7) 0;
    background: var(--color-bg-elevated);
    border-radius: 0;
    border-top: 1px solid var(--color-border);
  }

  /* If the publication-card lives inside a `.publication-card-list` (or any
     parent that wants a clean leading edge), the first card drops its top
     hairline. Most consumers already use grid `gap` so this is harmless. */
  .publication-card:first-child {
    border-top: 0;
  }

  .publication-card__head {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-uppercase);
    text-transform: uppercase;
    line-height: 1;
  }

  .publication-card__year {
    color: var(--color-accent);
  }

  .publication-card__journal {
    color: var(--color-text-muted);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-wide);
    text-transform: none;
  }
  .publication-card__journal::before {
    content: '·';
    margin-right: var(--space-2);
    color: var(--color-text-muted);
  }

  .publication-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: var(--fw-bold);
    line-height: var(--lh-snug);
    color: var(--color-text-heading);
  }

  .publication-card__title-link {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size var(--transition);
  }
  .publication-card__title-link:hover {
    background-size: 100% 1px;
  }
  .publication-card__title-link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 3px;
    border-radius: var(--radius-xs);
  }

  .publication-card__authors {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    color: var(--color-text-secondary);
    line-height: var(--lh-normal);
  }

  .publication-card__abstract {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-primary);
  }

  .publication-card__actions {
    margin-top: var(--space-2);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .publication-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: var(--fw-semibold);
    color: var(--color-link);
    text-decoration: none;
    transition: color var(--transition);
  }
  .publication-card__link:hover {
    color: var(--color-link-hover);
  }
  .publication-card__link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 3px;
    border-radius: var(--radius-xs);
  }
  .publication-card__link svg {
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .publication-card {
      padding: var(--space-8) 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .publication-card__link { transition: none; }
  }
</style>
