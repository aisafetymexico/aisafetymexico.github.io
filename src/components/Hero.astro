---
/**
 * Hero — Home variant.
 *
 * Spec: docs/DESIGN-SYSTEM.md §6.2; Task #8.
 *
 * Pattern reference (docs/INSPIRATION.md):
 *  - A1 (Editorial hero with serif/heavy headline + supporting paragraph)
 *  - A2 (Two-column hero on desktop → single-column stack on mobile,
 *        adapted as image + centered content stack here)
 *  - A8 (Solid brand band — navy overlay surface for high contrast)
 *
 * Layout: full-bleed navy-overlay band. Image stacks above centered content
 * (eyebrow → h1 → subtitle → CTAs) on mobile; on desktop the image keeps the
 * top of the column and the content centers below within the hero container.
 *
 * Props:
 *  - overline?:    small uppercase wayfinding label (e.g. "AI SAFETY MEXICO")
 *  - title:        main headline (Playfair display)
 *  - subtitle?:    supporting paragraph
 *  - image:        ImgRef shown above the content block
 *  - primaryCta:   primary CTA (filled copper)
 *  - secondaryCta?:secondary CTA (outline on dark)
 *
 * Tokens only — no literal hex values, no new hues introduced.
 */
import type { ImgRef, CtaRef } from '../lib/types';

export interface Props {
  overline?: string;
  title: string;
  subtitle?: string;
  image: ImgRef;
  primaryCta: Pick<CtaRef, 'label' | 'href'> & { external?: boolean };
  secondaryCta?: Pick<CtaRef, 'label' | 'href'> & { external?: boolean };
}

const { overline, title, subtitle, image, primaryCta, secondaryCta } = Astro.props;

if (!title) throw new Error('Hero: `title` is required.');
if (!image || !image.src) throw new Error('Hero: `image` (with src + alt) is required.');
if (!primaryCta?.href || !primaryCta?.label) {
  throw new Error('Hero: `primaryCta` requires `label` and `href`.');
}

const imgSrc = typeof image.src === 'string' ? image.src : image.src.src;
const ctaRel = (cta?: { external?: boolean }) =>
  cta?.external ? 'noopener noreferrer' : undefined;
const ctaTarget = (cta?: { external?: boolean }) =>
  cta?.external ? '_blank' : undefined;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <div class="hero__image">
      <img src={imgSrc} alt={image.alt} loading="eager" decoding="async" />
    </div>

    <div class="hero__content">
      {overline && (
        <p class="hero__overline role-eyebrow role-eyebrow--xl">{overline}</p>
      )}

      <h1 id="hero-title" class="hero__title">{title}</h1>

      {subtitle && <p class="hero__subtitle">{subtitle}</p>}

      <div class="hero__actions">
        <a
          class="hero__cta hero__cta--primary"
          href={primaryCta.href}
          target={ctaTarget(primaryCta)}
          rel={ctaRel(primaryCta)}
        >{primaryCta.label}</a>

        {secondaryCta && (
          <a
            class="hero__cta hero__cta--secondary"
            href={secondaryCta.href}
            target={ctaTarget(secondaryCta)}
            rel={ctaRel(secondaryCta)}
          >{secondaryCta.label}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--color-bg-overlay-dark);
    color: var(--color-text-on-dark);
    /* Mobile-first: tighter padding; scaled up on tablet/desktop */
    padding-block: var(--space-12) var(--space-10);
    display: flex;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: var(--space-14) var(--space-12);
      min-height: 540px;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding-block: var(--space-16) var(--space-14);
      min-height: 620px;
    }
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-8);
    width: 100%;
    max-width: var(--container-hero);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  @media (min-width: 480px) {
    .hero__inner {
      padding-inline: var(--container-padding-md);
    }
  }

  @media (min-width: 768px) {
    .hero__inner {
      gap: var(--space-9);
    }
  }

  .hero__image {
    width: 100%;
    max-width: 260px;
    margin-inline: auto;
    order: 0;
  }

  @media (min-width: 768px) {
    .hero__image {
      max-width: 480px;
    }
  }

  @media (min-width: 1024px) {
    .hero__image {
      max-width: 820px;
    }
  }

  .hero__image img {
    width: 100%;
    height: auto;
    /* Polish-rand (RAND-DIFF §2.5): RAND home photo is square-edge editorial,
       no radius, no drop shadow. */
    border-radius: 0;
  }

  .hero__content {
    width: 100%;
    max-width: 780px;
    order: 1;
  }

  .hero__overline {
    /* Use gold on navy surface for stronger contrast (per §1.3) */
    color: var(--color-accent-secondary);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-tight);
    /* Dark-mode subtle (PALETTE-MAPPING §4.5): align with PageHero h1 →
       peach so the home headline carries the same focal poster weight as
       interior pages. (QA-DARKMODE-VISUAL top-5 #2 / EDITORIAL-DARKMODE.) */
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--fs-lead);
    font-weight: var(--fw-regular);
    line-height: var(--lh-loose);
    color: var(--color-text-on-dark-muted);
    margin-inline: auto;
    margin-bottom: var(--space-8);
    max-width: 640px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Hero CTAs — token-only treatment matching .btn-hero from style.css.
     Polish-rand (RAND-DIFF §6.1, §6.2): no shadow-cta, no transform on
     hover; only background/border colour shifts. */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--space-9);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-wide);
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    text-decoration: none;
    transition:
      background var(--transition),
      border-color var(--transition),
      color var(--transition);
  }

  .hero__cta--primary {
    /* CTA tokens INVERT in dark-subtle (PALETTE-MAPPING §0/§4):
       --color-cta-bg = peach-500, --color-cta-text = bg-base. */
    background: var(--color-cta-bg);
    color: var(--color-cta-text);
    border-color: var(--color-cta-bg);
  }
  .hero__cta--primary:hover,
  .hero__cta--primary:focus-visible {
    background: var(--color-cta-bg-hover);
    border-color: var(--color-cta-bg-hover);
    color: var(--color-cta-text);
  }

  .hero__cta--secondary {
    background: transparent;
    color: var(--color-text-on-dark);
    border-color: var(--color-border-on-dark);
  }
  .hero__cta--secondary:hover,
  .hero__cta--secondary:focus-visible {
    background: var(--cream-text-faint);
    border-color: var(--color-text-on-dark);
    color: var(--color-text-on-dark);
  }

  /* Tight mobile (≤480) — slightly smaller image cap to keep title prominent */
  @media (max-width: 479px) {
    .hero__image {
      max-width: 200px;
    }
    .hero__cta {
      width: 100%;
    }
  }
</style>
