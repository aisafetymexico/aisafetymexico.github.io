---
/**
 * ScrollReveal — fade-in wrapper using IntersectionObserver.
 *
 * Spec:
 *  - docs/DESIGN-SYSTEM.md §6.5 (`ScrollReveal.astro`).
 *
 * Behaviour:
 *  - Renders `as` element (default: <div>) wrapping the slot.
 *  - Initial state: opacity 0, slight translateY.
 *  - When the element intersects viewport (threshold), `is-revealed` is added
 *    → triggers transition.
 *  - One-shot: observer disconnects after reveal.
 *  - Respects `prefers-reduced-motion`: no transform/opacity animation, simply
 *    visible immediately.
 *  - Idempotent: same boot guard pattern as the rest of the suite.
 *
 * Props:
 *  - as?: string (default 'div')
 *  - delay?: number ms (default 0) — staggers the animation start
 *  - threshold?: number (default 0.15) — fraction visible before revealing
 *  - duration?: number ms (default 600)
 *  - once?: boolean (default true) — disconnect after first reveal
 */
export interface Props {
  as?: string;
  delay?: number;
  threshold?: number;
  duration?: number;
  once?: boolean;
  class?: string;
}

const {
  as: Tag = 'div',
  delay = 0,
  threshold = 0.15,
  duration = 600,
  once = true,
  class: className,
} = Astro.props;
---

<Tag
  class:list={['scroll-reveal', className]}
  data-scroll-reveal
  data-delay={String(delay)}
  data-threshold={String(threshold)}
  data-duration={String(duration)}
  data-once={once ? 'true' : 'false'}
  style={`--sr-duration:${duration}ms;--sr-delay:${delay}ms`}
>
  <slot />
</Tag>

<script>
  (() => {
    const ATTR = 'data-scroll-reveal-bound';

    const reveal = (el: HTMLElement) => {
      el.classList.add('is-revealed');
    };

    const init = () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = Array.from(
        document.querySelectorAll<HTMLElement>('[data-scroll-reveal]')
      ).filter(el => el.getAttribute(ATTR) !== '1');

      targets.forEach(el => el.setAttribute(ATTR, '1'));

      if (reduced || !('IntersectionObserver' in window)) {
        // No motion budget OR no IO → reveal immediately, no animation.
        targets.forEach(reveal);
        return;
      }

      // Group elements by threshold so each gets its own observer.
      const groups = new Map<number, HTMLElement[]>();
      for (const el of targets) {
        const t = parseFloat(el.getAttribute('data-threshold') || '0.15');
        const arr = groups.get(t) || [];
        arr.push(el);
        groups.set(t, arr);
      }

      groups.forEach((els, threshold) => {
        const obs = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              reveal(el);
              if (el.getAttribute('data-once') !== 'false') {
                obs.unobserve(el);
              }
            }
          },
          { threshold, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach(el => obs.observe(el));
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .scroll-reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity var(--sr-duration, 600ms) ease var(--sr-delay, 0ms),
      transform var(--sr-duration, 600ms) ease var(--sr-delay, 0ms);
    will-change: opacity, transform;
  }
  .scroll-reveal.is-revealed {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
