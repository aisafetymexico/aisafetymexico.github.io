---
/**
 * /en/projects/ai-safety-connect — AI Safety Connect deep-dive (English locale).
 *
 * English sibling of src/pages/projects/ai-safety-connect.astro. Mirrors
 * structure 1:1 per docs/I18N-ARCHITECTURE.md §2. The PDF embed pattern is
 * preserved verbatim — only labels change to English.
 */
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PageHero from '../../../components/PageHero.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import Callout from '../../../components/Callout.astro';
import FactList from '../../../components/FactList.astro';
import KeyFacts from '../../../components/KeyFacts.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import CtaSection from '../../../components/CtaSection.astro';
import { t } from '../../../lib/i18n';

const project = await getEntry('projects', 'ai-safety-connect');
if (!project) {
  throw new Error('AI Safety Connect entry missing in src/content/projects/ai-safety-connect.md');
}
const data = project.data;

const paperPath = data.paperUrl ?? '/Papers/AI_Safety_Connect_Final_Report.pdf';

// Meta bar chips — type-only, no leading glyph.
const metaChips = [
  { text: 'SPAR · Supervised Program for Alignment Research' },
  { text: 'International team' },
  { text: 'Final report available' },
  { text: `${data.team.length} co-researchers` },
];

// Methodology fact list — eyebrow label / value pairs.
const methodologyItems = [
  {
    label: 'Objective',
    value:
      'Minimize the structural coordination gap between academic research and AI safety communities.',
  },
  {
    label: 'Methodology',
    value:
      'An integrated platform that maps authors, publications, and thematic areas through a structured taxonomy, semantic search, and scalable data pipelines.',
  },
  {
    label: 'International team',
    value: data.team.map((p) => p.name).join(', '),
  },
];

// Role translations for the international SPAR team.
const roleEn: Record<string, string> = {
  'Co-investigador': 'Co-researcher',
  'Co-investigadora': 'Co-researcher',
};

const teamItems = data.team.map((person) => ({
  label: (person.role && roleEn[person.role]) || person.role || 'Co-researcher',
  value: person.name,
}));

// Related projects
const enRelatedSummaries: Record<string, string> = {
  vigia:
    'A platform for analyzing AI governance and digital sovereignty in Mexico, born out of the AI Governance course in collaboration with ENAIS.',
};

const allProjects = await getCollection('projects', ({ data: d }: { data: { draft?: boolean } }) => d.draft !== true);
const related = allProjects
  .filter((p) => (p.data.slug ?? p.slug) !== 'ai-safety-connect')
  .slice(0, 1)
  .map((p) => {
    const slug = p.data.slug ?? p.slug;
    return {
      title: p.data.title,
      badge: p.data.badge,
      description: enRelatedSummaries[slug] ?? p.data.summary,
      image: p.data.cover,
      href: `/en/projects/${slug}`,
    };
  });

const breadcrumb = {
  items: [
    { label: t('en', 'breadcrumb.home'), href: '/en' },
    { label: 'Projects', href: '/en/projects' },
    { label: 'AI Safety Connect' },
  ],
};
---

<BaseLayout
  title="AI Safety Connect · Project · AI Safety Mexico"
  description="AI Safety Connect: a platform developed within SPAR to systematically map AI safety research and reduce the gap between academia and community."
  lang="en"
  pathname="/en/projects/ai-safety-connect"
  ogImage={data.poster?.src as string | undefined}
>
  <Header slot="header" navActivePath="/en/projects" lang="en" />

  <PageHero
    title="AI Safety Connect"
    description="A platform to systematically map AI safety research and reduce the gap between academia and community."
    breadcrumb={breadcrumb}
    lang="en"
  />

  {/* Meta bar */}
  <section class="section section--compact section--base" aria-label="Project information">
    <div class="container">
      <KeyFacts facts={metaChips} />
    </div>
  </section>

  {/* Overview */}
  <section class="section section--base" aria-labelledby="aisc-overview-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Summary"
        title="What is AI Safety Connect?"
        id="aisc-overview-heading"
      />
      <Callout tone="highlight">
        <p>
          <strong>AI Safety Connect</strong> is a platform to systematically map
          AI safety research and reduce the gap between academia and
          communities of practice.
        </p>
      </Callout>
      <div class="prose">
        <p>
          The project was developed within the <strong>Supervised Program for
          Alignment Research (SPAR)</strong>, an international program that
          connects emerging talent with established researchers in alignment.
          AI Safety Mexico participated as the Mexican host of the collaboration
          that produced this final report.
        </p>
        <p>
          The core hypothesis of the project is that there is a
          <strong>structural coordination gap</strong> between those producing
          AI safety research and those consuming it to design policy, products,
          or training programs. A platform with a consistent taxonomy and
          semantic search lowers the cost of discovery and opens the door to
          articulating shared agendas.
        </p>
      </div>
    </div>
  </section>

  {/* Methodology */}
  <section class="section section--base" aria-labelledby="aisc-methodology-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Methodology"
        title="How it is built"
        description="The platform relies on three complementary components: structured taxonomy, semantic search, and scalable data pipelines."
        id="aisc-methodology-heading"
      />
      <FactList items={methodologyItems} />
    </div>
  </section>

  {/* Paper / Publication */}
  <section class="section section--base section--edge-accent" aria-labelledby="aisc-paper-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Publication"
        title="Final report"
        description="The document synthesizes the findings, design decisions, and future work of the SPAR collaboration."
        id="aisc-paper-heading"
      />

      <div class="aisc-paper-actions">
        <a
          class="aisc-paper-cta aisc-paper-cta--primary"
          href={paperPath}
          target="_blank"
          rel="noopener noreferrer"
        >
          Open PDF in new tab
          <span aria-hidden="true">↗</span>
        </a>
        <a
          class="aisc-paper-cta aisc-paper-cta--secondary"
          href={paperPath}
          download
        >
          Download report
          <span aria-hidden="true">↓</span>
        </a>
      </div>

      <div class="aisc-pdf-viewer" aria-label="AI Safety Connect final report viewer">
        <object
          data={paperPath}
          type="application/pdf"
          width="100%"
          height="800"
        >
          <p class="aisc-pdf-fallback">
            Your browser cannot display the embedded PDF.
            <a href={paperPath} target="_blank" rel="noopener noreferrer">
              Open the report in a new tab
            </a>.
          </p>
        </object>
      </div>
    </div>
  </section>

  {/* Team */}
  <section class="section section--base" aria-labelledby="aisc-team-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="International team"
        title="Co-researchers"
        description="The SPAR collaboration brought together a geographically distributed team with experience in alignment, evaluations, and data infrastructure."
        id="aisc-team-heading"
      />
      <FactList items={teamItems} />
    </div>
  </section>

  {/* Acknowledgements */}
  <section class="section section--base" aria-labelledby="aisc-ack-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Acknowledgements"
        title="Programs and partners"
        id="aisc-ack-heading"
      />
      <div class="prose">
        <p>
          AI Safety Connect exists thanks to the <strong>SPAR — Supervised
          Program for Alignment Research</strong> program, which brought
          together the international team and provided academic mentorship. We
          thank the mentors who accompanied the methodological design and the
          review of results, as well as the communities of practice that
          provided feedback during development.
        </p>
        <p>
          AI Safety Mexico participated as the Mexican host, connecting the
          team with local partners and bringing a Mexican perspective to the
          design of the mapping.
        </p>
      </div>
    </div>
  </section>

  {/* Related projects */}
  {related.length > 0 && (
    <section class="section section--base" aria-labelledby="aisc-related-heading">
      <div class="container">
        <SectionHeading
          eyebrow="Keep exploring"
          title="Other projects"
          id="aisc-related-heading"
        />
        <div class="aisc-related-grid">
          {related.map((card) => (
            <ProjectCard
              title={card.title}
              badge={card.badge}
              description={card.description}
              image={card.image}
              href={card.href}
              lang="en"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaSection
    title="Read the full report"
    description="The final report documents findings, design decisions, and future work."
    ctaLabel="Open the PDF"
    ctaHref={paperPath}
    ctaExternal={true}
  />

  <Footer slot="footer" lang="en" />
</BaseLayout>

<style>
  .prose p {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4);
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose strong {
    color: var(--color-text-heading);
    font-weight: var(--fw-semibold);
  }

  /* Paper actions */
  .aisc-paper-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-7);
  }

  .aisc-paper-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    letter-spacing: var(--ls-wide);
    border-radius: var(--radius-pill);
    transition:
      background var(--transition),
      color var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  .aisc-paper-cta--primary {
    background: var(--color-cta-bg);
    color: var(--color-cta-text);
    box-shadow: var(--shadow-cta);
  }
  .aisc-paper-cta--primary:hover,
  .aisc-paper-cta--primary:focus-visible {
    background: var(--color-cta-bg-hover);
    color: var(--color-cta-text);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .aisc-paper-cta--secondary {
    background: transparent;
    color: var(--color-link);
    border: 1px solid var(--color-border-accent);
  }
  .aisc-paper-cta--secondary:hover,
  .aisc-paper-cta--secondary:focus-visible {
    background: var(--color-accent-soft);
    color: var(--color-link-hover);
    transform: translateY(-2px);
  }

  /* PDF viewer */
  .aisc-pdf-viewer {
    width: 100%;
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .aisc-pdf-viewer object {
    display: block;
    width: 100%;
    min-height: 480px;
  }

  @media (min-width: 768px) {
    .aisc-pdf-viewer object {
      min-height: 800px;
    }
  }

  .aisc-pdf-fallback {
    padding: var(--space-6);
    margin: 0;
    font-family: var(--font-body);
    color: var(--color-text-secondary);
  }

  .aisc-pdf-fallback a {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .aisc-pdf-fallback a:hover {
    color: var(--color-link-hover);
  }

  /* Related grid */
  .aisc-related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  @media (min-width: 768px) {
    .aisc-related-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .aisc-paper-cta {
      transition: none;
    }
    .aisc-paper-cta:hover {
      transform: none;
    }
  }
</style>
