---
/**
 * /en/projects/vigia — VIGÍA project deep-dive (English locale).
 *
 * English sibling of src/pages/projects/vigia.astro. Mirrors structure 1:1
 * per docs/I18N-ARCHITECTURE.md §2. The "Special Recognition · AI Safety
 * Collab 2025" badge stays as-is (award name).
 */
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PageHero from '../../../components/PageHero.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import Callout from '../../../components/Callout.astro';
import FactList from '../../../components/FactList.astro';
import KeyFacts from '../../../components/KeyFacts.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import CtaSection from '../../../components/CtaSection.astro';
import { t } from '../../../lib/i18n';

const project = await getEntry('projects', 'vigia');
if (!project) {
  throw new Error('VIGÍA project entry missing in src/content/projects/vigia.md');
}
const data = project.data;

// Meta bar chips (KeyFacts component) — type-only, no leading glyph.
const metaChips = [
  { text: 'Special Recognition · AI Safety Collab 2025' },
  { text: 'Governance · Digital sovereignty' },
  { text: 'Mexico' },
  { text: `Team of ${data.team.length} collaborators` },
  { text: 'In active development' },
];

// Role translations for the VIGÍA team. Spanish roles in the content collection
// are mapped to their English equivalents per task brief.
const roleEn: Record<string, string> = {
  'Cofundadora · Concepción de la plataforma': 'Co-founder · Platform conception',
  'Cofundador · Concepción de la plataforma': 'Co-founder · Platform conception',
  'Diseño': 'Design',
  'Advisory · Curso de Governance': 'Advisory · AI Governance course',
};

const teamItems = data.team.map((person) => ({
  label: (person.role && roleEn[person.role]) || person.role || 'Collaborator',
  value: person.name,
}));

// External resources — same label/value treatment as the team list.
const resourceItems = [
  data.externalUrl
    ? { label: 'Platform', value: 'vigia-observatorio.github.io' }
    : null,
  { label: 'Founding partner', value: 'ENAIS — AI Governance course' },
  { label: 'Recognition', value: 'AI Safety Collab 2025' },
].filter(Boolean) as { label: string; value: string }[];

// Related project — AI Safety Connect
const enRelatedSummaries: Record<string, string> = {
  'ai-safety-connect':
    'A platform to systematically map AI safety research and reduce the gap between academia and communities of practice.',
};

const allProjects = await getCollection('projects', ({ data: d }: { data: { draft?: boolean } }) => d.draft !== true);
const related = allProjects
  .filter((p) => (p.data.slug ?? p.slug) !== 'vigia')
  .slice(0, 1)
  .map((p) => {
    const slug = p.data.slug ?? p.slug;
    return {
      title: p.data.title,
      badge: p.data.badge,
      description: enRelatedSummaries[slug] ?? p.data.summary,
      image: p.data.cover,
      href: `/en/projects/${slug}`,
    };
  });

const breadcrumb = {
  items: [
    { label: t('en', 'breadcrumb.home'), href: '/en' },
    { label: 'Projects', href: '/en/projects' },
    { label: 'VIGÍA' },
  ],
};
---

<BaseLayout
  title="VIGÍA · Project · AI Safety Mexico"
  description="VIGÍA is AI Safety Mexico's platform for analyzing AI governance and digital sovereignty in Mexico. Special Recognition · AI Safety Collab 2025."
  lang="en"
  pathname="/en/projects/vigia"
  ogImage={data.cover?.src as string | undefined}
>
  <Header slot="header" navActivePath="/en/projects" lang="en" />

  <PageHero
    title="VIGÍA"
    description="A platform for analyzing AI governance and digital sovereignty in Mexico."
    breadcrumb={breadcrumb}
    lang="en"
  />

  {/* Meta bar */}
  <section class="section section--compact section--base" aria-label="Project information">
    <div class="container">
      <KeyFacts facts={metaChips} />
    </div>
  </section>

  {/* Overview */}
  <section class="section section--base" aria-labelledby="vigia-overview-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Summary"
        title="What is VIGÍA?"
        id="vigia-overview-heading"
      />
      <div class="prose">
        <p>
          <strong>VIGÍA</strong> — <em>Valoración de Impactos Gubernamentales de
          Inteligencia Artificial</em> (Assessment of Governmental Impacts of
          Artificial Intelligence) — is a platform under development that maps,
          analyzes, and communicates public decisions about artificial intelligence
          in Mexico. It emerged as part of the projects of the AI Governance course
          taught by <strong>ENAIS</strong> and AI Safety Mexico, and has since
          grown into a standalone initiative.
        </p>
        <p>
          The observatory aims to close a concrete gap: there is no public,
          systematic, and auditable source documenting how the Mexican government
          makes decisions about AI — what it procures, what it regulates, what it
          deploys, and under what oversight. VIGÍA articulates that information
          for researchers, journalists, civil society, and decision-makers.
        </p>
      </div>
    </div>
  </section>

  {/* Recognition */}
  <section class="section section--base" aria-labelledby="vigia-recognition-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Recognition"
        title="Special Recognition · AI Safety Collab 2025"
        id="vigia-recognition-heading"
      />
      <Callout tone="highlight">
        <p>
          VIGÍA received <strong>Special Recognition</strong> at
          <strong>AI Safety Collab 2025</strong>, a global program for AI safety
          research projects. The recognition validates the project's situated
          approach and opens doors for future international collaborations.
        </p>
      </Callout>
    </div>
  </section>

  {/* Methodology */}
  <section class="section section--base" aria-labelledby="vigia-methodology-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Methodology"
        title="How we work"
        description="VIGÍA combines documentary tracking, qualitative analysis, and structured communication."
        id="vigia-methodology-heading"
      />
      <div class="prose">
        <p>
          The platform articulates three layers of work: (1) <strong>documentary
          tracking</strong> of procurements, regulations, public consultations, and
          government deployments involving AI systems; (2) <strong>qualitative
          analysis</strong> of each case under categories of governance, risk, and
          accountability; and (3) <strong>structured communication</strong> in
          formats accessible to both technical and non-technical audiences —
          briefs, timelines, and interpretive summaries.
        </p>
        <p>
          The approach prioritizes <strong>verifiability</strong>: every case
          documented in VIGÍA links to its primary source (official gazettes,
          minutes, communiqués) and is accompanied by a methodological note on
          how the information was obtained and classified.
        </p>
      </div>
    </div>
  </section>

  {/* Team */}
  <section class="section section--base" aria-labelledby="vigia-team-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Team"
        title="Who builds it"
        description="VIGÍA is a collaborative effort between its co-founders, a design collaboration, and the guidance of instructors from the AI Governance course where the idea first took shape."
        id="vigia-team-heading"
      />
      <FactList items={teamItems} />
    </div>
  </section>

  {/* Resources */}
  <section class="section section--base" aria-labelledby="vigia-resources-heading">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Resources"
        title="Links and references"
        id="vigia-resources-heading"
      />
      <FactList items={resourceItems} />

      {data.externalUrl && (
        <p class="vigia-link">
          <a class="vigia-link__cta" href={data.externalUrl} target="_blank" rel="noopener noreferrer">
            Visit the VIGÍA platform
            <span aria-hidden="true">↗</span>
          </a>
        </p>
      )}
    </div>
  </section>

  {/* Related projects */}
  {related.length > 0 && (
    <section class="section section--base" aria-labelledby="vigia-related-heading">
      <div class="container">
        <SectionHeading
          eyebrow="Keep exploring"
          title="Other projects"
          id="vigia-related-heading"
        />
        <div class="vigia-related-grid">
          {related.map((card) => (
            <ProjectCard
              title={card.title}
              badge={card.badge}
              description={card.description}
              image={card.image}
              href={card.href}
              lang="en"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaSection
    title="See VIGÍA live"
    description="The platform updates with every new case documented. Visit it to explore the observatory."
    ctaLabel="Go to vigia-observatorio.github.io"
    ctaHref={data.externalUrl ?? 'https://vigia-observatorio.github.io/index-en.html'}
    ctaExternal={true}
  />

  <Footer slot="footer" lang="en" />
</BaseLayout>

<style>
  .prose p {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4);
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  .prose strong {
    color: var(--color-text-heading);
    font-weight: var(--fw-semibold);
  }

  .vigia-link {
    margin: var(--space-6) 0 0;
  }

  .vigia-link__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    letter-spacing: var(--ls-wide);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-cta);
    transition:
      background var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  .vigia-link__cta:hover,
  .vigia-link__cta:focus-visible {
    background: var(--color-cta-bg-hover);
    color: var(--color-cta-text);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .vigia-related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  @media (min-width: 768px) {
    .vigia-related-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vigia-link__cta {
      transition: none;
    }
    .vigia-link__cta:hover {
      transform: none;
    }
  }
</style>
