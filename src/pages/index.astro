---
/**
 * `/` — Home (Gateway curado).
 *
 * Spec: docs/ARCHITECTURE.md §2 (Home), Task #12.
 * Pattern: docs/INSPIRATION.md A1 (editorial hero) + A3 (feature + side cards)
 *          + A6 (restrained two-tone surfaces).
 *
 * Deliberate restraint: this page is a curated gateway — NOT a long-scroll
 * synthesis of every section. Each block sends visitors to a deeper page.
 *
 * Sections:
 *   1. Hero — full-bleed navy, image + overline + h1 + subtitle + 2 CTAs.
 *   2. GSH spotlight — full-width ActivityCard for the Global South AIS
 *      Challenge, surfaced immediately after the hero.
 *   3. Featured pillars — FeatureGrid (4 entries: Investigación, Programas,
 *      Proyectos, Equipo) on warm surface.
 *   4. StatBar — 4 impact stats on navy.
 *   5. Highlights curados — 2 cards (proyecto insignia + publicación). GSH
 *      vive arriba en el spotlight, así que aquí dejamos solo dos destacados
 *      bien curados (RAND-editorial: 2 fuertes > 3 forzados).
 *   6. CtaSection — navy closing band, single CTA → /get-involved.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatBar from '../components/StatBar.astro';
import Card from '../components/Card.astro';
import ActivityCard from '../components/ActivityCard.astro';
import CtaSection from '../components/CtaSection.astro';

const pillars = [
  {
    title: 'Investigación',
    description:
      'Trabajo original y colaborativo en alineación, interpretabilidad y gobernanza técnica. Saber más →',
    href: '/research',
  },
  {
    title: 'Programas',
    description:
      'Cursos abiertos y a la medida que adaptan los marcos contemporáneos de AI safety al contexto mexicano. Saber más →',
    href: '/programs',
  },
  {
    title: 'Proyectos',
    description:
      'Iniciativas aplicadas como VIGÍA y AI Safety Connect: abiertas, auditables y orientadas a producir conocimiento utilizable. Saber más →',
    href: '/projects',
  },
  {
    title: 'Equipo',
    description:
      'Investigadoras, ingenieros y profesionales multidisciplinarios articulados desde México. Saber más →',
    href: '/team',
  },
];

const stats = [
  { number: '6+', label: 'Cursos impartidos' },
  { number: '30+', label: 'Participantes formados' },
  { number: '1', label: 'Publicación revisada por pares' },
  { number: '8', label: 'Personas en el equipo' },
];

// -------- GSH spotlight (sección 2) --------
// Mirrors the spotlight on /activities (single ActivityCard, side-by-side at
// md+). Keeping copy aligned with that page so the two surfaces tell the same
// story.
const gshSpotlight = {
  title: 'The Global South AIS Challenge',
  date: 'Marzo 2026',
  description:
    'Hackatón regional de seguridad en IA organizado con Apart Research. Convoca a investigadoras, ingenieros y profesionales del sur global a producir prototipos, evaluaciones y propuestas de gobernanza durante un fin de semana intensivo.',
  link: '/global-south-challenge',
  image: {
    src: '/images/gsh-event-card.png',
    alt: 'Imagen promocional del Global South AIS Challenge.',
  },
};
---

<BaseLayout
  title="AI Safety Mexico — Investigación, educación y gobernanza de IA"
  description="Organización mexicana sin fines de lucro dedicada a la investigación, educación y gobernanza responsable de la IA en México."
  pathname="/"
  ogImage="/images/observatorio.png"
>
  <Header slot="header" currentPath="/" />

  <Hero
    overline="AI SAFETY MEXICO"
    title="Seguridad y gobernanza de la IA, desde México."
    subtitle="Investigamos, formamos y construimos comunidad alrededor de la seguridad de la inteligencia artificial. Construimos las bases técnicas y de gobernanza necesarias para que México tome decisiones informadas sobre IA."
    image={{ src: '/images/observatorio.png', alt: 'Observatorio de AI Safety Mexico' }}
    primaryCta={{ label: 'Conoce nuestros proyectos', href: '/projects' }}
    secondaryCta={{ label: 'Colabora', href: '/get-involved' }}
  />

  <!-- 2 · GSH spotlight (Global South AIS Challenge) -->
  <section class="section section--base section--compact" aria-labelledby="home-gsh-spotlight">
    <div class="container">
      <SectionHeading
        eyebrow="Evento destacado"
        title="Global South AIS Challenge"
        description="Nuestra iniciativa regional más visible: un hackatón abierto que convoca a la comunidad del sur global a producir trabajo concreto en seguridad de IA."
        align="center"
        id="home-gsh-spotlight"
      />
      <div class="home-spotlight">
        <ActivityCard
          title={gshSpotlight.title}
          date={gshSpotlight.date}
          description={gshSpotlight.description}
          image={gshSpotlight.image}
          link={gshSpotlight.link}
        />
      </div>
    </div>
  </section>

  <!-- 3 · Featured pillars (gateway de 4) -->
  <section class="section section--base section--edge-accent">
    <div class="container">
      <SectionHeading
        eyebrow="Qué hacemos"
        title="Cuatro frentes, una sola misión."
        description="Cada pilar enlaza a la página dedicada con detalles, materiales y formas de colaborar."
        align="center"
      />
      <FeatureGrid items={pillars} />
    </div>
  </section>

  <!-- 4 · Stat bar -->
  <StatBar stats={stats} />

  <!-- 5 · Highlights curados (GSH ya vive arriba en el spotlight) -->
  <section class="section section--base">
    <div class="container">
      <SectionHeading
        eyebrow="Destacados"
        title="Trabajo reciente."
        description="Un proyecto y una publicación para asomarse al pulso de la organización."
        align="center"
      />

      <div class="home-highlights">
        <Card
          href="/projects/vigia"
          badge="Proyecto insignia"
          title="VIGÍA"
          description="Plataforma para observar el ecosistema regulatorio de IA en México. Special Recognition · AI Safety Collab 2025."
          padding="md"
          bordered
        />
        <Card
          href="/research"
          badge="Publicación"
          title="A Pilot Survey on AI Safety in Yucatan"
          description="Estudio piloto sobre percepciones, riesgos y prácticas locales en torno a la IA, publicado en RCS · IPN."
          padding="md"
          bordered
        />
      </div>
    </div>
  </section>

  <!-- 6 · CTA closing band -->
  <CtaSection
    title="¿Buscas colaborar?"
    description="Investigadores, instituciones y aliados: hay múltiples vías para sumarse al trabajo de AI Safety Mexico."
    ctaLabel="Conoce las vías de colaboración"
    ctaHref="/get-involved"
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Highlights grid — 2 curated cards: stack on mobile → side-by-side at md+.
     (Was 3-up; GSH moved to the top spotlight in §2, so we deliberately keep
     only two well-curated highlights to avoid forcing a filler card.) */
  .home-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: var(--container-narrow, 860px);
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .home-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-9);
    }
  }

  @media (min-width: 1024px) {
    .home-highlights {
      gap: var(--space-10);
    }
  }

  /* GSH spotlight — single full-width ActivityCard, mirrored from
     /activities .spotlight (RAND editorial; no shadow / no lift). On md+,
     switch the card to a 50/50 image-left, body-right layout. */
  .home-spotlight :global(.activity-card) {
    max-width: var(--container-narrow, 860px);
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .home-spotlight :global(.activity-card) {
      flex-direction: row;
      align-items: stretch;
    }
    .home-spotlight :global(.activity-card__media) {
      flex: 0 0 50%;
      aspect-ratio: auto;
    }
    .home-spotlight :global(.activity-card__body) {
      flex: 1 1 50%;
      justify-content: center;
    }
    .home-spotlight :global(.activity-card__title) {
      font-size: var(--fs-h4);
    }
  }
</style>
