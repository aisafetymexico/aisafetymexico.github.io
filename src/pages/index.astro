---
/**
 * `/` — Home (Gateway curado).
 *
 * Spec: docs/ARCHITECTURE.md §2 (Home), Task #12.
 * Pattern: docs/INSPIRATION.md A1 (editorial hero) + A3 (feature + side cards)
 *          + A6 (restrained two-tone surfaces).
 *
 * Deliberate restraint: this page is a curated gateway — NOT a long-scroll
 * synthesis of every section. Each block sends visitors to a deeper page.
 *
 * Sections:
 *   1. Hero — full-bleed navy, image + overline + h1 + subtitle + 2 CTAs.
 *   2. Featured pillars — FeatureGrid (4 entries: Investigación, Programas,
 *      Proyectos, Equipo) on warm surface.
 *   3. StatBar — 4 impact stats on navy.
 *   4. Highlights curados — 3 cards (1 actividad, 1 proyecto, 1 publicación).
 *   5. CtaSection — navy closing band, single CTA → /get-involved.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatBar from '../components/StatBar.astro';
import Card from '../components/Card.astro';
import CtaSection from '../components/CtaSection.astro';

const pillars = [
  {
    title: 'Investigación',
    description:
      'Trabajo original y colaborativo en alineación, evaluaciones de seguridad y gobernanza técnica. Saber más →',
    href: '/research',
  },
  {
    title: 'Programas',
    description:
      'Cursos abiertos y a la medida que adaptan los marcos contemporáneos de AI safety al contexto regional. Saber más →',
    href: '/programs',
  },
  {
    title: 'Proyectos',
    description:
      'Iniciativas aplicadas como VIGÍA y AI Safety Connect: abiertas, auditables y orientadas a producir conocimiento utilizable. Saber más →',
    href: '/projects',
  },
  {
    title: 'Equipo',
    description:
      'Investigadoras, ingenieros y profesionales multidisciplinarios articulados desde México hacia Latinoamérica. Saber más →',
    href: '/team',
  },
];

const stats = [
  { number: '6+', label: 'Cursos impartidos' },
  { number: '30+', label: 'Participantes formados' },
  { number: '3', label: 'Publicaciones' },
  { number: '10+', label: 'Investigadores' },
];
---

<BaseLayout
  title="AI Safety Mexico — Investigación, educación y gobernanza de IA"
  description="Organización mexicana sin fines de lucro dedicada a la investigación, educación y gobernanza responsable de la IA en México y América Latina."
  pathname="/"
  ogImage="/images/observatorio.png"
>
  <Header slot="header" currentPath="/" />

  <Hero
    overline="AI SAFETY MEXICO · MX-LATAM"
    title="Seguridad y gobernanza de la IA, desde México hacia Latinoamérica."
    subtitle="Investigamos, formamos y dialogamos con políticas públicas para que el desarrollo de la inteligencia artificial incorpore las preocupaciones, valores y contextos del sur global."
    image={{ src: '/images/observatorio.png', alt: 'Observatorio de AI Safety Mexico' }}
    primaryCta={{ label: 'Conoce nuestros proyectos', href: '/projects' }}
    secondaryCta={{ label: 'Colabora', href: '/get-involved' }}
  />

  <!-- 2 · Featured pillars (gateway de 4) -->
  <section class="section section--base section--edge-accent">
    <div class="container">
      <SectionHeading
        eyebrow="Qué hacemos"
        title="Cuatro frentes, una sola misión."
        description="Cada pilar enlaza a la página dedicada con detalles, materiales y formas de colaborar."
        align="center"
      />
      <FeatureGrid items={pillars} />
    </div>
  </section>

  <!-- 3 · Stat bar -->
  <StatBar stats={stats} />

  <!-- 4 · Highlights curados -->
  <section class="section section--base">
    <div class="container">
      <SectionHeading
        eyebrow="Destacados"
        title="Trabajo reciente."
        description="Una actividad, un proyecto y una publicación para asomarse al pulso de la organización."
        align="center"
      />

      <div class="home-highlights">
        <Card
          href="/global-south-challenge"
          badge="Evento activo"
          title="Global South AIS Challenge"
          description="Hackathon regional organizado con Apart Research para articular las voces del sur global en seguridad de IA."
          padding="md"
          bordered
        />
        <Card
          href="/projects/vigia"
          badge="Proyecto insignia"
          title="VIGÍA"
          description="Plataforma para observar el ecosistema regulatorio de IA en México. Special Recognition · AI Safety Collab 2025."
          padding="md"
          bordered
        />
        <Card
          href="/research"
          badge="Publicación"
          title="A Pilot Survey on AI Safety in Yucatan"
          description="Estudio piloto sobre percepciones, riesgos y prácticas locales en torno a la IA, publicado en RCS · IPN."
          padding="md"
          bordered
        />
      </div>
    </div>
  </section>

  <!-- 5 · CTA closing band -->
  <CtaSection
    title="¿Buscas colaborar?"
    description="Investigadores, instituciones y aliados: hay múltiples vías para sumarse al trabajo de AI Safety Mexico."
    ctaLabel="Conoce las vías de colaboración"
    ctaHref="/get-involved"
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* 3-up highlights grid: stack on mobile → 3 cols on desktop. */
  .home-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .home-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-9);
    }
  }

  @media (min-width: 1024px) {
    .home-highlights {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-10);
    }
  }
</style>
