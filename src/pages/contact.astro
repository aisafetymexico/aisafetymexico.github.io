---
/**
 * /contact — Lowest-friction email contact page.
 *
 * Spec: docs/ARCHITECTURE.md §2 (`/contact`) + §6 (ContentPage template).
 *
 * Editorial decision (Task #19):
 *   /contact is a SEPARATE simple page (not a redirect / alias to
 *   /get-involved#contacto). Rationale:
 *     - ARCHITECTURE.md §2 explicitly lists /contact as its own page with
 *       intro, email/LinkedIn/Instagram block, response time and optional
 *       region/location context.
 *     - The footer (Footer.astro) already links to `/contact` — having a
 *       real page avoids a redirect hop.
 *     - User-intent split: /get-involved is for higher-intent
 *       collaboration inquiries (form + 3 vías). /contact is for visitors
 *       who only want the email + socials with no form friction.
 *   This page does NOT include the ContactForm: visitors who want a form
 *   are funneled to /get-involved#contacto via the CTA at the bottom.
 *
 * Page composition:
 *   1. SiteHeader (sticky)
 *   2. PageHero — eyebrow + h1 + lede + breadcrumb
 *   3. Direct-contact channels (email canónico + LinkedIn + Instagram)
 *   4. Response-time / region-context note
 *   5. CtaSection — "¿Quieres colaborar?" → /get-involved
 *   6. SiteFooter
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CtaSection from '../components/CtaSection.astro';

const pathname = '/contact';

const breadcrumb = {
  items: [
    { label: 'Inicio', href: '/' },
    { label: 'Contacto' },
  ],
};
---

<BaseLayout
  title="Contacto — AI Safety Mexico"
  description="Escríbenos a contact@aismx.org o conéctate con nosotros en LinkedIn e Instagram. Respondemos a la mayoría de los mensajes en una semana."
  pathname={pathname}
  ogImage="/images/aisafetymx_logo.webp"
>
  <Header slot="header" currentPath={pathname} />

  <PageHero
    eyebrow="Contacto"
    title="Escríbenos"
    description="Si tienes una pregunta, una propuesta o quieres saber más sobre nuestros programas e investigaciones, puedes contactarnos por cualquiera de los canales abajo."
    breadcrumb={breadcrumb}
  />

  <section class="page-section" aria-labelledby="channels-heading">
    <div class="container container--narrow">
      <h2 id="channels-heading" class="contact__heading">Canales</h2>

      <ul class="contact__list" role="list">
        <li class="contact__item">
          <span class="contact__label">Correo electrónico</span>
          <a class="contact__value" href="mailto:contact@aismx.org">
            contact@aismx.org
          </a>
          <p class="contact__hint">Canal principal — preferimos correo para propuestas formales.</p>
        </li>

        <li class="contact__item">
          <span class="contact__label">LinkedIn</span>
          <a
            class="contact__value"
            href="https://www.linkedin.com/company/ai-safety-mexico/"
            target="_blank"
            rel="noopener noreferrer"
          >
            linkedin.com/company/ai-safety-mexico
          </a>
          <p class="contact__hint">Para conectar profesionalmente y recibir actualizaciones.</p>
        </li>

        <li class="contact__item">
          <span class="contact__label">Instagram</span>
          <a
            class="contact__value"
            href="https://www.instagram.com/aisafetymx/"
            target="_blank"
            rel="noopener noreferrer"
          >
            @aisafetymx
          </a>
          <p class="contact__hint">Para seguir actividades, eventos y galería de la comunidad.</p>
        </li>
      </ul>

      <div class="contact__meta">
        <p class="contact__meta-item">
          <strong>Tiempo de respuesta.</strong> Respondemos a la mayoría de los
          mensajes en un plazo de una semana hábil.
        </p>
        <p class="contact__meta-item">
          <strong>Región.</strong> Operamos desde México con foco en América Latina;
          también colaboramos con organizaciones internacionales.
        </p>
      </div>
    </div>
  </section>

  <CtaSection
    title="¿Quieres colaborar con nosotros?"
    description="Si tu mensaje es una propuesta de colaboración —investigación conjunta, programas educativos o eventos—, visita Colabora para más detalles y un formulario dedicado."
    ctaLabel="Ver formas de colaborar"
    ctaHref="/get-involved#contacto"
  />

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-section {
    padding-block: var(--space-10);
    background: var(--color-bg-base);
  }
  @media (min-width: 768px) {
    .page-section {
      padding-block: var(--space-12);
    }
  }

  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }
  .container--narrow {
    max-width: var(--container-narrow);
  }
  @media (min-width: 480px) {
    .container {
      padding-inline: var(--container-padding-md);
    }
  }

  .contact__heading {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: var(--fw-bold);
    line-height: var(--lh-snug);
    letter-spacing: var(--ls-tight);
    color: var(--color-text-heading);
    margin: 0 0 var(--space-7);
  }

  .contact__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin: 0 0 var(--space-9);
    padding: 0;
    list-style: none;
  }

  .contact__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-6);
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-xs);
  }

  .contact__label {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-uppercase);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .contact__value {
    font-family: var(--font-body);
    font-size: var(--fs-h6);
    font-weight: var(--fw-semibold);
    color: var(--color-text-heading);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition);
    word-break: break-word;
  }
  .contact__value:hover,
  .contact__value:focus-visible {
    color: var(--color-link-hover);
    border-bottom-color: var(--color-link-hover);
  }

  .contact__hint {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    line-height: var(--lh-relaxed);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .contact__meta {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact__meta-item {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-primary);
    margin: 0;
  }

  .contact__meta-item :global(strong) {
    color: var(--color-text-heading);
    font-weight: var(--fw-semibold);
  }
</style>
